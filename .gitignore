# Ignore everything at root by default
/*

# Track scripts and project metadata
!/*.py
!/.gitignore
!/README.md
!/LICENSE
!/boarddocs_unids.json
!/.github/

# Website (Cloudflare Worker): entry point, config, and static assets
!/worker.js
!/wrangler.toml
!/public/

# Docs + changelog (this project is meant to be downloaded and carried forward)
!/CHANGELOG.md
!/docs/

# Transient verifier output — written only when drift is detected, consumed
# by the workflow's issue step, never committed.
verify-report.txt
issue_body.txt
